{
  "name": "trustpulse-root",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "functions/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "seed": "ts-node scripts/seed-sessions.ts",
    "emulators": "firebase emulators:start",
    "dev:dashboard": "npm run dev --workspace=apps/dashboard"
  },
  "devDependencies": {
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
